# Anthropic API key — required
ANTHROPIC_API_KEY=your-key-here

# Optional: override the main streaming model (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL_MAIN=
# ANTHROPIC_MODEL=

# Light model for intake routing + sidebar titles (defaults to Haiku-class)
# ANTHROPIC_MODEL_LIGHT=

# Set to 1 to skip intake + schema slicing (legacy full CLAUDE.md every request)
# DISABLE_AI_INTAKE=

# ── v1 auth (email + password, cookie sessions) ───────────────────────────
# Self sign-up is allowed for INTERNAL_SIGNUP_DOMAINS and for emails listed in
# EXTERNAL_PILOT_ALLOWLIST (comma-separated, lowercase recommended).

# Optional absolute path to the JSON data file (default: server/data/app-data.json under the app root)
# PW_DATA_FILE=

# Persistent session cookie lifetime in days (1–366, default 30)
# SESSION_MAX_DAYS=30

# Domains eligible for self sign-up (default: projectworks.com,projectworks.io)
# INTERNAL_SIGNUP_DOMAINS=projectworks.com,projectworks.io

# Comma-separated pilot emails outside the internal domains (may be empty)
# EXTERNAL_PILOT_ALLOWLIST=

# Reserved for future signed cookies / SSO handoff — set in production when used
SESSION_SECRET=

# Comma-separated list of internal email domains (reserved for future tenant/RBAC)
# e.g. INTERNAL_DOMAINS=projectworks.com,projectworks.io
INTERNAL_DOMAINS=

# Comma-separated list of domains allowed to embed this app in an iframe
# Used to set Content-Security-Policy: frame-ancestors
# Include 'localhost' for local development
# e.g. ALLOWED_EMBED_DOMAINS=projectworks.com,projectworks.io,localhost
ALLOWED_EMBED_DOMAINS=

# ── Live schema connection (schemaFetcher.js) ─────────────────────────────
# This is the most important upgrade path for the app.
#
# When DB_HOST is set, schemaFetcher.js connects to the Projectworks
# reporting database before every /api/chat request and replaces the static
# schema in CLAUDE.md with a live introspection of INFORMATION_SCHEMA.
# The result: zero schema drift, no manual CLAUDE.md edits required.
#
# Leave DB_HOST empty to use the static schema in CLAUDE.md (current default).
DB_HOST=
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=

# Set to 'true' for self-signed certificates (dev/staging environments only)
DB_TRUST_CERT=false
