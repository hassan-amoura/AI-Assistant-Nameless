<?xml version="1.0" encoding="utf-8"?>
<!--
  IISNode configuration for Node.js on Azure App Service.
  Azure's IIS layer forwards all requests to server.js via the iisnode module.
  Do not change nodeProcessCommandLine unless you need a specific Node binary.
-->
<configuration>
  <system.webServer>

    <handlers>
      <!-- Route all traffic through iisnode to server.js -->
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Do not rewrite requests for static files under .azure/ -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^\.azure/.*" />
          <action type="None" />
        </rule>

        <!-- Route everything else to server.js -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="node"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

    <!-- Disable directory browsing -->
    <directoryBrowse enabled="false" />

    <!-- Security headers — frame-ancestors is set dynamically by server.js -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
